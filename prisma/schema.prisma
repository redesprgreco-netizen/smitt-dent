// prisma/schema.prisma
// Smitt-Dent — Schema para Supabase (PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Rol {
  admin
  doctora
  visitante
}

enum EstadoUsuario {
  pendiente
  activo
  inactivo
}

enum EstadoCita {
  pendiente
  confirmada
  cancelada
  completada
}

enum EstadoExpediente {
  activo
  inactivo
}

enum EstadoPieza {
  sin_tratamiento
  tratado
  pendiente
  extraccion
}

enum EstadoTratamiento {
  pendiente
  en_curso
  realizado
}

enum MetodoPago {
  efectivo
  transferencia
  tarjeta
}

enum EstadoPago {
  activo
  anulado
}

enum TipoMovimiento {
  entrada
  salida
}

model Usuario {
  id           Int           @id @default(autoincrement())
  nombre       String        @db.VarChar(80)
  apellido     String        @db.VarChar(80)
  correo       String        @unique @db.VarChar(120)
  passwordHash String        @map("password_hash") @db.VarChar(255)
  rol          Rol
  colorAgenda  String?       @map("color_agenda") @db.VarChar(7)
  estado       EstadoUsuario @default(pendiente)
  aprobadoPor  Int?          @map("aprobado_por")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  // Relaciones
  aprobador            Usuario?             @relation("AprobacionUsuario", fields: [aprobadoPor], references: [id])
  aprobados            Usuario[]            @relation("AprobacionUsuario")
  citasAsignadas       Cita[]               @relation("CitaDoctora")
  citasCreadas         Cita[]               @relation("CitaCreador")
  expedientes          Expediente[]         @relation("ExpedienteDoctora")
  expedientesCreados   Expediente[]         @relation("ExpedienteCreador")
  historialCreado      HistorialClinico[]   @relation("HistorialCreador")
  odontogramaUpdates   OdontogramaPieza[]   @relation("OdontogramaUpdater")
  odontogramaHistorial OdontogramaHistorial[] @relation("OdontogramaChanger")
  planTratamiento      PlanTratamiento[]    @relation("PlanCreador")
  pagosRegistrados     Pago[]               @relation("PagoCreador")
  pagosAnulados        Pago[]               @relation("PagoAnulador")
  inventarioMovimientos InventarioMovimiento[] @relation("MovimientoCreador")
  bitacora             Bitacora[]           @relation("BitacoraUsuario")

  @@map("usuarios")
}

model Cita {
  id               Int        @id @default(autoincrement())
  nombrePaciente   String     @map("nombre_paciente") @db.VarChar(80)
  apellidoPaciente String     @map("apellido_paciente") @db.VarChar(80)
  asunto           String     @db.VarChar(200)
  fecha            DateTime   @db.Date
  hora             DateTime   @db.Time()
  notas            String?    @db.Text
  doctoraId        Int        @map("doctora_id")
  expedienteId     Int?       @map("expediente_id")
  estado           EstadoCita @default(pendiente)
  createdBy        Int        @map("created_by")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  doctora    Usuario     @relation("CitaDoctora", fields: [doctoraId], references: [id])
  creador    Usuario     @relation("CitaCreador", fields: [createdBy], references: [id])
  expediente Expediente? @relation(fields: [expedienteId], references: [id])

  @@map("citas")
}

model Expediente {
  id            Int              @id @default(autoincrement())
  folio         String           @unique @db.VarChar(12)
  nombre        String           @db.VarChar(80)
  apellido      String           @db.VarChar(80)
  fechaNacimiento DateTime?      @map("fecha_nacimiento") @db.Date
  telefono      String?          @db.VarChar(20)
  correo        String?          @db.VarChar(120)
  alergias      String?          @db.Text
  motivoInicial String?          @map("motivo_inicial") @db.Text
  doctoraId     Int              @map("doctora_id")
  estado        EstadoExpediente @default(activo)
  createdBy     Int              @map("created_by")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  doctora         Usuario              @relation("ExpedienteDoctora", fields: [doctoraId], references: [id])
  creador         Usuario              @relation("ExpedienteCreador", fields: [createdBy], references: [id])
  citas           Cita[]
  historial       HistorialClinico[]
  odontograma     OdontogramaPieza[]
  odontogramaHist OdontogramaHistorial[]
  planTratamiento PlanTratamiento[]
  pagos           Pago[]

  @@map("expedientes")
}

model HistorialClinico {
  id             Int      @id @default(autoincrement())
  expedienteId   Int      @map("expediente_id")
  titulo         String   @db.VarChar(200)
  descripcion    String   @db.Text
  esCorreccion   Boolean  @default(false) @map("es_correccion")
  notaOriginalId Int?     @map("nota_original_id")
  createdBy      Int      @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")

  expediente   Expediente        @relation(fields: [expedienteId], references: [id])
  creador      Usuario           @relation("HistorialCreador", fields: [createdBy], references: [id])
  notaOriginal HistorialClinico? @relation("CorreccionNota", fields: [notaOriginalId], references: [id])
  correcciones HistorialClinico[] @relation("CorreccionNota")

  @@map("historial_clinico")
}

model OdontogramaPieza {
  id           Int         @id @default(autoincrement())
  expedienteId Int         @map("expediente_id")
  numeroPieza  Int         @map("numero_pieza") @db.SmallInt
  estado       EstadoPieza @default(sin_tratamiento)
  notas        String?     @db.Text
  updatedBy    Int         @map("updated_by")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  expediente Expediente @relation(fields: [expedienteId], references: [id])
  updater    Usuario    @relation("OdontogramaUpdater", fields: [updatedBy], references: [id])

  @@unique([expedienteId, numeroPieza])
  @@map("odontograma_piezas")
}

model OdontogramaHistorial {
  id             Int         @id @default(autoincrement())
  expedienteId   Int         @map("expediente_id")
  numeroPieza    Int         @map("numero_pieza") @db.SmallInt
  estadoAnterior EstadoPieza @map("estado_anterior")
  estadoNuevo    EstadoPieza @map("estado_nuevo")
  changedBy      Int         @map("changed_by")
  changedAt      DateTime    @default(now()) @map("changed_at")

  expediente Expediente @relation(fields: [expedienteId], references: [id])
  changer    Usuario    @relation("OdontogramaChanger", fields: [changedBy], references: [id])

  @@map("odontograma_historial")
}

model PlanTratamiento {
  id           Int               @id @default(autoincrement())
  expedienteId Int               @map("expediente_id")
  concepto     String            @db.VarChar(200)
  piezas       String?           @db.VarChar(100)
  cantidad     Decimal           @default(1) @db.Decimal(6, 2)
  precioUnitario Decimal         @map("precio_unitario") @db.Decimal(10, 2)
  subtotal     Decimal           @db.Decimal(10, 2)
  descuentoPct Decimal           @default(0) @map("descuento_pct") @db.Decimal(5, 2)
  estado       EstadoTratamiento @default(pendiente)
  createdBy    Int               @map("created_by")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  expediente Expediente @relation(fields: [expedienteId], references: [id])
  creador    Usuario    @relation("PlanCreador", fields: [createdBy], references: [id])

  @@map("plan_tratamiento")
}

model Pago {
  id             Int        @id @default(autoincrement())
  folioRecibo    String     @unique @map("folio_recibo") @db.VarChar(15)
  expedienteId   Int        @map("expediente_id")
  monto          Decimal    @db.Decimal(10, 2)
  metodoPago     MetodoPago @map("metodo_pago")
  concepto       String?    @db.VarChar(200)
  estado         EstadoPago @default(activo)
  motivoAnulacion String?   @map("motivo_anulacion") @db.Text
  anuladoPor     Int?       @map("anulado_por")
  anuladoAt      DateTime?  @map("anulado_at")
  createdBy      Int        @map("created_by")
  createdAt      DateTime   @default(now()) @map("created_at")

  expediente Expediente @relation(fields: [expedienteId], references: [id])
  creador    Usuario    @relation("PagoCreador", fields: [createdBy], references: [id])
  anulador   Usuario?   @relation("PagoAnulador", fields: [anuladoPor], references: [id])

  @@map("pagos")
}

model InventarioArticulo {
  id           Int      @id @default(autoincrement())
  nombre       String   @db.VarChar(150)
  categoria    String?  @db.VarChar(80)
  unidadMedida String   @map("unidad_medida") @db.VarChar(30)
  stockActual  Decimal  @default(0) @map("stock_actual") @db.Decimal(8, 2)
  stockMinimo  Decimal  @default(0) @map("stock_minimo") @db.Decimal(8, 2)
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  movimientos InventarioMovimiento[]

  @@map("inventario_articulos")
}

model InventarioMovimiento {
  id         Int            @id @default(autoincrement())
  articuloId Int            @map("articulo_id")
  tipo       TipoMovimiento
  cantidad   Decimal        @db.Decimal(8, 2)
  notas      String?        @db.Text
  createdBy  Int            @map("created_by")
  createdAt  DateTime       @default(now()) @map("created_at")

  articulo InventarioArticulo @relation(fields: [articuloId], references: [id])
  creador  Usuario            @relation("MovimientoCreador", fields: [createdBy], references: [id])

  @@map("inventario_movimientos")
}

model Bitacora {
  id             BigInt   @id @default(autoincrement())
  usuarioId      Int?     @map("usuario_id")
  accion         String   @db.VarChar(80)
  tablaAfectada  String   @map("tabla_afectada") @db.VarChar(60)
  registroId     Int?     @map("registro_id")
  valorAnterior  Json?    @map("valor_anterior")
  valorNuevo     Json?    @map("valor_nuevo")
  ipAddress      String?  @map("ip_address") @db.VarChar(45)
  createdAt      DateTime @default(now()) @map("created_at")

  usuario Usuario? @relation("BitacoraUsuario", fields: [usuarioId], references: [id])

  @@map("bitacora")
}
